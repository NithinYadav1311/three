# Backend Environment Variables (.env file should be in /backend directory)

# MongoDB Configuration (REQUIRED)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=hrai_production

# Groq AI Configuration (REQUIRED for AI features)
GROQ_API_KEY=your_groq_api_key_here

# Google OAuth Configuration (REQUIRED for authentication)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (UPDATE for production)
FRONTEND_URL=https://your-vercel-app.vercel.app

# CORS Configuration (UPDATE for production)
CORS_ORIGINS=https://your-vercel-app.vercel.app,http://localhost:3000
